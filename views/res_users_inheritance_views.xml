<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_users_form_inherit_helpdesk" model="ir.ui.view">
        <field name="name">res.users.form.inherit.helpdesk</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Helpdesk" 
                      name="helpdesk" 
                      groups="odoo_help_desk.group_helpdesk_supervisor">
                    <group string="Supervisor Settings">
                        <field name="subordinate_ids" widget="many2many_tags" 
                               help="Select users that this supervisor can manage"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>