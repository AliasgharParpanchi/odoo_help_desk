<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- فرم (Form View) -->
    <record id="view_help_desk_ticket_form" model="ir.ui.view">
        <field name="name">help.desk.ticket.form</field>
        <field name="model">help.desk.ticket</field>
        <field name="arch" type="xml">
            <form string="Ticket">
                <group>
                    <group>
                        <field name="title"/>
                        <field name="ticket_number"/>
                        <field name="problem_description"/>
                        <field name="customer_id"/>
                        <field name="assignee_id" widget="many2many_tags"/>
                    </group>
                    <group>
                        <field name="solution"/>
                        <field name="priority"/>
                        <field name="state"/>
                        <field name="days_open"/>
                        <field name="active"/>
                    </group>
                </group>
            </form>
        </field>
    </record>  

    <!-- لیست (Tree/List View) -->
    <record id="view_help_desk_ticket_list" model="ir.ui.view">
        <field name="name">help.desk.ticket.list</field>
        <field name="model">help.desk.ticket</field>
        <field name="arch" type="xml">
            <list create="1" delete="1" multi_edit="1" string="Ticket List">
                <field name="ticket_number"/>
                <field name="title"/>
                <field name="customer_id"/>
                <field name="assignee_id"/>
                <field name="state"/>
                <field name="priority"/>
                <field name="problem_description"/>
            </list>
        </field> 
    </record>

    <record id="view_help_desk_ticket_kanban" model="ir.ui.view">
        <field name="name">help.desk.ticket.kanban</field>
        <field name="model">help.desk.ticket</field>
        <field name="priority" eval="1"/>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile ticket_kanban" sample="1" default_group_by="state">
                <progressbar field="priority" colors='{"low": "success", "medium": "warning", "high": "danger"}'/>
                <templates>
                    <t t-name="card">
                        <field name="title" class="fw-bold fs-5"/>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>
        

    <!-- اکشن پنجره (Action) -->
    <record id="action_help_desk_ticket" model="ir.actions.act_window">
        <field name="name">Ticket</field>
        <field name="res_model">help.desk.ticket</field>
        <field name="view_mode">kanban,list,form</field>
    </record>   <!-- ✅ اینجا حتماً /record باشد -->
</odoo>